# ── Required ──────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── Persona (personalise JARVIS for yourself) ─────────────────────────────────
JARVIS_OWNER_NAME=Boss
JARVIS_CPU=a high-performance CPU
JARVIS_RAM=high-capacity RAM
JARVIS_GPU=a dedicated GPU
JARVIS_STORAGE=fast NVMe SSD storage
JARVIS_OS=Windows

# ── Telegram Bot (optional) ───────────────────────────────────────────────────
# Leave blank to disable the Telegram integration.
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_ID=
